# サービス種別: "smart-ex"（スマートEX） または "expy"（エクスプレス予約）
SERVICE_TYPE=smart-ex

# ※ ログインは資格情報を保存せず、ブラウザを表示して手入力で行います（ID/PWの設定は不要）。

# 領収書の宛名（自分の会社名などに変更。Web UIのフォームでも上書きできます）
RECIPIENT_NAME=上様

# PDF の出力先（未指定ならデスクトップ）。例: OUTPUT_DIR=~/Desktop/EX領収書
# OUTPUT_DIR=

# ログインセッションの保存先（次回以降は再ログイン不要）
STATE_FILE=./.auth/state.json

# 一覧の行に複数日付がある場合、ファイル名に使う日付の番号（0=行の最初の日付）
TRAVEL_DATE_INDEX=0

# ブラウザをヘッドレス実行するか（true/false）
HEADLESS=true

# ページ読み込みタイムアウト(ミリ秒)
TIMEOUT=30000

# デバッグ: 各ステップのスクショ/HTML を ./output に保存
DEBUG=false
